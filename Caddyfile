# HybridSocial production Caddyfile.
#
# Reads two env vars:
#   $DOMAIN          (required) — main public domain
#   $MEDIA_DOMAIN    (optional) — separate origin for user uploads
#                                  (recommended: media.<domain>)
#
# Topology:
#   * Main domain: full WAF (CrowdSec + Coraza/CRS) on every handler
#                  except /api/v1/streaming/* (long-lived WebSockets)
#   * Media domain: NO app-layer WAF. Static file serving only —
#                   ClamAV scans uploads inside the backend before
#                   they reach storage, and CrowdSec at the IP layer
#                   still applies via the global config.
{
	# Plugin order — both must come before reverse_proxy or they're
	# bypassed for proxied responses.
	order crowdsec first
	order coraza_waf before reverse_proxy

	# CrowdSec bouncer config. The agent runs in its own container
	# and exposes its LAPI on http://crowdsec:8080. The bouncer key
	# is registered out-of-band on first agent startup (see
	# crowdsec service env in docker-compose-production.yml).
	crowdsec {
		api_url http://crowdsec:8080
		api_key {$CROWDSEC_BOUNCER_CADDY_KEY}
		ticker_interval 15s
	}

	# Real client IP behind Cloudflare. The caddy-cloudflare-ip module
	# fetches CF's published edge ranges (refreshed every 12h) and marks
	# them trusted; the real visitor IP is then read from CF-Connecting-IP.
	# This feeds Caddy's client_ip to the CrowdSec bouncer, Coraza, logs,
	# and the app — so CrowdSec bans the attacker, not a Cloudflare edge.
	# Safe when DNS-only too: the header is only honored from these
	# trusted source IPs, so a direct client can't spoof it.
	servers {
		trusted_proxies cloudflare {
			interval 12h
			timeout 15s
		}
		client_ip_headers Cf-Connecting-Ip
	}
}


# ---------- Main domain ----------
{$DOMAIN:localhost} {
	# Behind Cloudflare: CF terminates public TLS and connects to this
	# origin over HTTPS. Self-signed is fine with CF SSL mode "Full" (CF
	# doesn't validate the origin cert), so no Let's Encrypt/ACME is needed.
	tls internal

	# WebSocket streaming — bypass Coraza (response-body scanning
	# breaks long-lived connections). CrowdSec still applies via
	# the global directive order.
	@streaming path /api/v1/streaming/*
	handle @streaming {
		reverse_proxy backend:4000 {
			# SSE must stream, not buffer. Without flush_interval -1 Caddy
			# buffers the response, so the client's EventSource never sees
			# the headers/heartbeats, times out, and reconnect-loops.
			flush_interval -1
			transport http {
				read_timeout 0
			}
		}
	}

	# Older self-service reset emails linked to /auth/reset-password, but
	# the SvelteKit route is /reset-password (so those links 404). Redirect
	# them — preserving the ?token= query — so already-sent emails work.
	@legacy_reset path /auth/reset-password
	handle @legacy_reset {
		redir * /reset-password?{query} 302
	}

	# Everything else gets the full WAF stack.
	handle {
		import /etc/caddy/waf.caddy

		@api path /api/* /.well-known/* /nodeinfo/* /inbox /users/* /actors/* /activities/* /oauth/* /media/* /proxy/*
		handle @api {
			reverse_proxy backend:4000
		}

		# SvelteKit frontend
		reverse_proxy frontend:3000
	}

	# Defense-in-depth response headers.
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	encode gzip zstd

	# JSON access log — CrowdSec's `crowdsecurity/caddy` parser
	# expects this format and reads from this exact path.
	log {
		output file /var/log/caddy/access.log {
			roll_size 100mb
			roll_keep 5
		}
		format json
	}
}
